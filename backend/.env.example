APP_NAME=Infinite Studio Backend
APP_ENV=development
DEFAULT_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# CORS allowed origins (comma-separated or JSON array)
ALLOWED_ORIGINS=http://localhost:15191,http://127.0.0.1:15191
# Or use JSON array format:
# ALLOWED_ORIGINS=["http://localhost:15191","http://127.0.0.1:15191"]

UPLOAD_MAX_MB=20
ACCOUNT_DATA_FILE=.data/account_store.db

# IMPORTANT: Set a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCOUNT_SECRET=

SIGNUP_BONUS_POINTS=120
ACCOUNT_SESSION_TTL_HOURS=720
WECHAT_PAY_MCHID=
WECHAT_PAY_APPID=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_APIV3_KEY=
# Must be HTTPS in production (localhost/127.0.0.1 allowed for dev)
WECHAT_PAY_NOTIFY_URL=https://your-domain.example.com/api/payments/wechat/notify
WECHAT_PAY_CERT_DIR=.data/wechatpay-cert
